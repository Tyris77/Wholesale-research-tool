# Environment variables for Wholesale Research Tool

# Groq API (AI Deal Analysis) - Sign up free at console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# FRED API (Market Data) - Sign up free at fred.stlouisfed.org
FRED_API_KEY=your_fred_api_key_here

# Google Maps (Property Maps) - Sign up at console.cloud.google.com
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Census Bureau API - Sign up at api.census.gov
CENSUS_API_KEY=your_census_api_key_here

# RealtyMole (Comps) - Sign up at realtymole.com
REALTYMOLE_API_KEY=your_realtymole_api_key_here

# OpenAI (Backup AI) - Sign up at platform.openai.com
OPENAI_API_KEY=your_openai_api_key_here

# Server config
NODE_ENV=development
PORT=5000
CORS_ORIGIN=http://localhost:4173
DATABASE_URL=./wholesale.db
